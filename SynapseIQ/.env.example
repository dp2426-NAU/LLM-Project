# ─────────────────────────────────────────────
#  LLM Provider — "openai" or "ollama"
# ─────────────────────────────────────────────
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────
#  Embeddings
# ─────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ─────────────────────────────────────────────
#  Storage
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION=synapseiq_corpus
ANALYTICS_DB_PATH=./synapseiq_analytics.db

# ─────────────────────────────────────────────
#  Pipeline Configuration
# ─────────────────────────────────────────────
CHUNK_SIZE=700
CHUNK_OVERLAP=80
RETRIEVAL_TOP_K=6
MIN_RELEVANCE_SCORE=0.30
MAX_AGENT_RETRIES=2
ENABLE_CRITIC_AGENT=true
ENABLE_VALIDATOR_AGENT=true

# ─────────────────────────────────────────────
#  Evaluation Thresholds
# ─────────────────────────────────────────────
COHERENCE_THRESHOLD=0.65
RELEVANCE_THRESHOLD=0.60
MIN_FACTUALITY_SCORE=0.55

# ─────────────────────────────────────────────
#  Cost Tracking (USD per 1K tokens)
# ─────────────────────────────────────────────
COST_PER_1K_INPUT_TOKENS=0.00015
COST_PER_1K_OUTPUT_TOKENS=0.00060

# ─────────────────────────────────────────────
#  App
# ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
